<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Scan report — {{ c.target }}</title>
<style>
  :root {
    --bg: #0f1117; --panel: #171a21; --line: #262b36;
    --text: #e6e8ee; --dim: #8b93a7;
    --crit: #b91c1c; --high: #dc2626; --med: #d97706;
    --low: #2563eb; --info: #64748b; --ok: #16a34a;
  }
  * { box-sizing: border-box; }
  body { margin:0; background:var(--bg); color:var(--text);
         font:14px/1.55 ui-sans-serif,system-ui,-apple-system,"Segoe UI",sans-serif; }
  .wrap { max-width:1100px; margin:0 auto; padding:40px 24px 80px; }
  h1 { font-size:26px; margin:0 0 4px; letter-spacing:-.01em; }
  h2 { font-size:16px; margin:38px 0 14px; text-transform:uppercase;
       letter-spacing:.09em; color:var(--dim); font-weight:600; }
  .sub { color:var(--dim); margin-bottom:28px; }
  .cards { display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:12px; }
  .card { background:var(--panel); border:1px solid var(--line);
          border-radius:10px; padding:16px 18px; }
  .card .n { font-size:28px; font-weight:650; letter-spacing:-.02em; }
  .card .l { color:var(--dim); font-size:12px; text-transform:uppercase;
             letter-spacing:.07em; margin-top:2px; }
  table { width:100%; border-collapse:collapse; background:var(--panel);
          border:1px solid var(--line); border-radius:10px; overflow:hidden; }
  th,td { padding:9px 12px; text-align:left; border-bottom:1px solid var(--line);
          font-size:13px; vertical-align:top; }
  th { color:var(--dim); font-weight:600; font-size:11px;
       text-transform:uppercase; letter-spacing:.07em; background:#12151c; }
  tr:last-child td { border-bottom:none; }
  td.num, th.num { text-align:right; font-variant-numeric:tabular-nums; }
  .pill { display:inline-block; padding:1px 8px; border-radius:999px;
          font-size:11px; font-weight:600; text-transform:uppercase;
          letter-spacing:.04em; color:#fff; }
  .critical{background:var(--crit)} .high{background:var(--high)}
  .medium{background:var(--med)} .low{background:var(--low)}
  .informational{background:var(--info)}
  .bar { height:7px; background:#232833; border-radius:4px; overflow:hidden;
         min-width:90px; margin-top:5px; }
  .bar span { display:block; height:100%; background:var(--low); }
  .agree { font-variant-numeric:tabular-nums; }
  .agree.multi { color:var(--ok); font-weight:650; }
  code { background:#12151c; padding:1px 5px; border-radius:4px;
         font-size:12px; color:#a8b3cf; word-break:break-all; }
  .muted { color:var(--dim); }
  .note { background:var(--panel); border:1px solid var(--line);
          border-left:3px solid var(--low); border-radius:8px;
          padding:14px 18px; color:var(--dim); margin-top:14px; }
  footer { margin-top:60px; color:var(--dim); font-size:12px;
           border-top:1px solid var(--line); padding-top:16px; }
</style>
</head>
<body><div class="wrap">

<h1>Vulnerability scan report</h1>
<div class="sub">
  Target <strong>{{ c.target }}</strong> &middot;
  {{ c.results|length }} scanners &middot;
  generated {{ generated }}
</div>

<div class="cards">
  <div class="card"><div class="n">{{ c.raw_count }}</div><div class="l">Raw findings</div></div>
  <div class="card"><div class="n">{{ c.unique_count }}</div><div class="l">Unique</div></div>
  <div class="card"><div class="n">{{ '%.0f'|format(c.dedup_ratio) }}%</div><div class="l">Duplication</div></div>
  <div class="card"><div class="n">{{ c.corroborated_count }}</div><div class="l">Multi-tool</div></div>
</div>

<h2>Severity distribution</h2>
<table>
  <tr><th>Severity</th><th class="num">Unique findings</th><th style="width:45%"></th></tr>
  {% set maxsev = (sev.values()|max) if sev else 1 %}
  {% for name in ['critical','high','medium','low','informational'] %}
  {% if sev.get(name) %}
  <tr>
    <td><span class="pill {{ name }}">{{ name }}</span></td>
    <td class="num">{{ sev[name] }}</td>
    <td><div class="bar"><span style="width:{{ (sev[name]/maxsev*100)|round }}%"></span></div></td>
  </tr>
  {% endif %}
  {% endfor %}
</table>

<h2>Scanner comparison</h2>
<table>
  <tr>
    <th>Tool</th><th>Version</th>
    <th class="num">Raw</th><th class="num">Unique</th>
    <th class="num">Exclusive</th><th class="num">Duration</th><th>Status</th>
  </tr>
  {% for tool, s in tools.items()|sort %}
  <tr>
    <td><strong>{{ tool }}</strong></td>
    <td class="muted">{{ s.version or '—' }}</td>
    <td class="num">{{ s.raw }}</td>
    <td class="num">{{ s.unique }}</td>
    <td class="num">{{ s.exclusive }}</td>
    <td class="num">{{ s.duration }}s</td>
    <td>{% if s.error %}<span class="pill high">failed</span>{% else %}<span class="muted">ok</span>{% endif %}</td>
  </tr>
  {% endfor %}
</table>
<div class="note">
  <strong>Exclusive</strong> counts findings no other scanner reported. A high
  exclusive count means the tool contributes coverage the others lack — which
  matters more than raw finding volume, since a single passive rule can emit
  one alert per URL.
</div>

<h2>Cross-tool agreement</h2>
<table>
  <tr><th>&nbsp;</th>{% for t in toolnames %}<th class="num">{{ t }}</th>{% endfor %}</tr>
  {% for a in toolnames %}
  <tr>
    <th>{{ a }}</th>
    {% for b in toolnames %}
    {% set v = matrix[(a,b)] %}
    <td class="num agree {% if a != b and v > 0 %}multi{% endif %}">{{ v if v else '·' }}</td>
    {% endfor %}
  </tr>
  {% endfor %}
</table>
<div class="note">
  Diagonal cells are each tool's own unique findings. Off-diagonal cells count
  findings that two tools independently identified as the same vulnerability,
  matched by fingerprint rather than by name.
</div>

<h2>OWASP Top 10 coverage</h2>
<table>
  <tr><th>Category</th><th class="num">Unique findings</th><th>Detected by</th></tr>
  {% for cat, n in owasp.items()|sort(attribute='1', reverse=true) %}
  <tr>
    <td>{{ cat }}</td>
    <td class="num">{{ n }}</td>
    <td class="muted">
      {% set detectors = [] %}
      {% for tool, cats in coverage.items() %}
        {% if cat in cats %}{% set _ = detectors.append(tool) %}{% endif %}
      {% endfor %}
      {{ detectors|join(', ') if detectors else '—' }}
    </td>
  </tr>
  {% endfor %}
</table>

<h2>Top findings</h2>
<table>
  <tr>
    <th>Severity</th><th>Finding</th><th>Location</th>
    <th>Tools</th><th class="num">Instances</th>
  </tr>
  {% for c2 in top %}
  <tr>
    <td><span class="pill {{ c2.finding.severity.value }}">{{ c2.finding.severity.value }}</span></td>
    <td>
      <strong>{{ c2.finding.name }}</strong><br>
      <span class="muted">
        {% if c2.finding.cwe_id %}CWE-{{ c2.finding.cwe_id }}{% endif %}
        {% if c2.finding.param %} &middot; param <code>{{ c2.finding.param }}</code>{% endif %}
      </span>
    </td>
    <td><code>{{ c2.finding.url|truncate(70) }}</code></td>
    <td class="agree {% if c2.corroborated %}multi{% endif %}">{{ c2.tools|join(', ') }}</td>
    <td class="num">{{ c2.instances }}</td>
  </tr>
  {% endfor %}
</table>

<footer>
  webvuln-orchestrator &middot; findings deduplicated by fingerprint
  (CWE + normalized URL + parameter + method), excluding tool identity.
</footer>

</div></body></html>
